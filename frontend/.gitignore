# =============================================
# frontend/.gitignore — Next.js
# =============================================

# Dependencies
/node_modules

# Next.js
/.next/
/out/

# Production build
/build

# Environment variables — KHÔNG BAO GIỜ commit
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
/coverage

# Misc
.DS_Store
*.pem
.vscode/
.idea/

# Yarn / pnpm (không dùng nhưng để tránh conflict)
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions